IMMICH_API_URL="http://your-immich-instance:2283/api"
IMMICH_API_KEY="your_api_key"
DB_NAME="immich"
DB_USER="immich"
# DB_PASSWORD is OPTIONAL. Leave it commented out for peer-auth (Unix socket) — works
# only when this script can reach the Postgres Unix socket AND the OS user maps to the
# DB user. For Immich-in-Docker setups, the socket lives inside the container, so set
# a password instead. The script will then use TCP via DB_HOST + DB_PORT.
# DB_PASSWORD="your_db_password"
DB_HOST="localhost"
DB_PORT="5432"
ML_API_URL="http://your-ml-service:3003/api"
# Specify the exact CLIP model name used by your Immich ML service
CLIP_MODEL_NAME="ViT-L-16-SigLIP-384__webli" # Example: ViT-B-32, ViT-L-14, ViT-SO400M-16-SigLIP2-384__webli

# Number of hours back to check for new assets
FETCH_HOURS=4

# Milliseconds to sleep between Immich write API calls (album add / archive) and ML
# embedding requests. 100ms = ~10 req/sec, safe for kdocker-class boxes. Override at
# runtime with --rate-limit-ms 0 to disable.
RATE_LIMIT_MS=100
